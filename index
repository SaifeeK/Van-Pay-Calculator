<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Van Pay Calculator</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0d0f14;
    --surface: #161a24;
    --card: #1e2433;
    --border: #2a3045;
    --accent: #4fffb0;
    --accent2: #ff6b6b;
    --accent3: #ffd166;
    --text: #e8eaf2;
    --muted: #6b7599;
    --radius: 12px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Syne', sans-serif;
    min-height: 100vh;
    padding: 40px 20px;
  }

  header {
    text-align: center;
    margin-bottom: 40px;
  }

  header h1 {
    font-size: 2.8rem;
    font-weight: 800;
    letter-spacing: -1px;
    background: linear-gradient(135deg, var(--accent), #00c4ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  header p {
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    font-size: 0.85rem;
    margin-top: 8px;
  }

  .input-area {
    max-width: 720px;
    margin: 0 auto 20px;
  }

  .input-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    margin-bottom: 10px;
    display: block;
  }

  textarea {
    width: 100%;
    height: 240px;
    background: var(--surface);
    border: 2px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 0.8rem;
    padding: 16px;
    resize: vertical;
    outline: none;
    transition: border-color 0.2s ease;
    line-height: 1.7;
  }

  textarea:focus { border-color: var(--accent); }
  textarea::placeholder { color: var(--muted); opacity: 0.5; }

  .btn-row {
    display: flex;
    justify-content: center;
    gap: 12px;
    max-width: 720px;
    margin: 0 auto 40px;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--accent);
    color: #000;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 12px 28px;
    border-radius: 99px;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .btn:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(79,255,176,0.3); }
  .btn.secondary { background: var(--card); color: var(--text); border: 1px solid var(--border); }
  .btn.secondary:hover { border-color: var(--accent); color: var(--accent); box-shadow: none; transform: none; }
  .btn.download { background: var(--card); color: var(--accent3); border: 1px solid rgba(255,209,102,0.3); }
  .btn.download:hover { background: rgba(255,209,102,0.08); border-color: var(--accent3); box-shadow: 0 8px 24px rgba(255,209,102,0.15); transform: translateY(-2px); }

  .error-box {
    background: rgba(255,107,107,0.1);
    border: 1px solid rgba(255,107,107,0.3);
    color: var(--accent2);
    border-radius: var(--radius);
    padding: 16px 20px;
    font-family: 'DM Mono', monospace;
    font-size: 0.82rem;
    max-width: 720px;
    margin: 0 auto 24px;
    display: none;
  }

  #results { max-width: 960px; margin: 0 auto; }

  .date-banner {
    max-width: 960px;
    margin: 0 auto 28px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 4px solid var(--accent);
    border-radius: var(--radius);
    padding: 14px 20px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .date-banner .date-icon { font-size: 1.3rem; }
  .date-banner .date-label { font-family: 'DM Mono', monospace; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); }
  .date-banner .date-value { font-size: 1.1rem; font-weight: 700; color: var(--accent); }

  .section-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    max-width: 960px;
    margin: 0 auto 16px;
  }

  .vehicle-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin-bottom: 24px;
    overflow: hidden;
    animation: fadeUp 0.4s ease both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .vehicle-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 24px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
    gap: 12px;
  }

  .vehicle-name {
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: -0.5px;
    font-family: 'DM Mono', monospace;
  }

  .vehicle-summary { display: flex; gap: 20px; flex-wrap: wrap; }
  .summary-chip { text-align: right; }
  .summary-chip .label { font-size: 0.65rem; font-family: 'DM Mono', monospace; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; }
  .summary-chip .value { font-size: 1.1rem; font-weight: 700; color: var(--text); }

  table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }

  thead th {
    padding: 10px 16px;
    text-align: left;
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    background: rgba(255,255,255,0.02);
    border-bottom: 1px solid var(--border);
  }

  tbody tr { border-bottom: 1px solid rgba(255,255,255,0.04); transition: background 0.15s; }
  tbody tr:hover { background: rgba(255,255,255,0.03); }
  tbody tr:last-child { border-bottom: none; }
  tbody td { padding: 12px 16px; font-family: 'DM Mono', monospace; }
  tbody td.name { font-family: 'Syne', sans-serif; font-weight: 500; }
  tbody td.money { text-align: right; }
  tbody td.green { color: var(--accent); font-weight: 500; }
  tbody td.yellow { color: var(--accent3); font-weight: 600; }

  tfoot td {
    padding: 12px 16px;
    font-family: 'DM Mono', monospace;
    font-weight: 600;
    background: rgba(79,255,176,0.05);
    border-top: 1px solid var(--border);
    text-align: right;
  }
  tfoot td:first-child { text-align: left; color: var(--muted); text-transform: uppercase; font-size: 0.7rem; font-weight: 400; }

  .global-totals {
    background: var(--surface);
    border: 1px solid rgba(79,255,176,0.2);
    border-radius: var(--radius);
    padding: 28px;
    margin-top: 8px;
    display: flex;
    gap: 32px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .global-totals .chip { text-align: center; }
  .global-totals .chip .label { font-family: 'DM Mono', monospace; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); margin-bottom: 6px; }
  .global-totals .chip .val { font-size: 1.9rem; font-weight: 800; color: var(--accent); }
</style>
</head>
<body>

<header>
  <h1>Van Pay Calculator</h1>
  <p>Copy your dispatch table → paste below → instant pay breakdown per vehicle</p>
</header>

<div class="input-area">
  <span class="input-label">📋 Paste dispatch data here</span>
  <textarea id="pasteInput" placeholder="5/2/26 1:08 PM
1952422
5/2/26 9:41 AM
Mr. Daniel Lebarron
VAN
DCT442
92.40
55.44
0.00
0.00
0.00
0.00
55.44
...paste the full table"></textarea>
</div>

<div class="btn-row">
  <button class="btn" id="calcBtn">⚡ Calculate Pay</button>
  <button class="btn download" id="downloadBtn" style="display:none">⬇ Download Report</button>
  <button class="btn secondary" id="resetBtn">✕ Clear</button>
</div>

<div class="error-box" id="errorBox"></div>
<div id="results"></div>

<script>
const pasteInput  = document.getElementById('pasteInput');
const calcBtn     = document.getElementById('calcBtn');
const downloadBtn = document.getElementById('downloadBtn');
const resetBtn    = document.getElementById('resetBtn');
const errorBox    = document.getElementById('errorBox');
const resultsDiv  = document.getElementById('results');
let lastDate = '';

// ─── Parser ───────────────────────────────────────────────────────────────────
// Each trip block is exactly 13 lines:
//  0  changed-on datetime  e.g. "5/2/26 1:08 PM"
//  1  res#                 e.g. "1952422"
//  2  trip datetime        e.g. "5/2/26 9:41 AM"
//  3  name
//  4  serviceType          e.g. "VAN" or "Shared"
//  5  vehicle ID           e.g. "DCT442"
//  6  vehicle fare
//  7  vehicle pay          ← used for 40% calc
//  8  gratuity             ← added on top
//  9  fuel
// 10  offpeak
// 11  extras
// 12  total (ignored — we recalculate)

function parseTrips(raw) {
  const lines = raw.split('\n').map(l => l.trim()).filter(l => l !== '');
  const dateRx = /^\d{1,2}\/\d{1,2}\/\d{2,4}\s+\d{1,2}:\d{2}\s*(AM|PM)$/i;
  const numRx  = /^-?\d+(\.\d+)?$/;
  const trips  = [];

  let i = 0;
  while (i <= lines.length - 13) {
    // Must start with a datetime line
    if (!dateRx.test(lines[i])) { i++; continue; }

    const changedOn  = lines[i];
    const res        = lines[i+1];
    const tripDate   = lines[i+2];
    const name       = lines[i+3];
    const svcType    = lines[i+4];
    const vehicle    = lines[i+5];
    const vFare      = lines[i+6];
    const vPayStr    = lines[i+7];
    const gratStr    = lines[i+8];
    // lines 9-11: fuel, offpeak, extras — ignored
    // line 12: total — ignored

    // Validate: vehicle pay, gratuity must be numbers; vehicle should look like an ID
    if (!numRx.test(vPayStr) || !numRx.test(gratStr) || vehicle.length < 3) {
      i++; continue;
    }

    trips.push({
      changedOn,
      res,
      tripDate,
      name,
      svcType,
      vehicle,
      vPay:     parseFloat(vPayStr),
      gratuity: parseFloat(gratStr),
    });
    i += 13;
  }
  return trips;
}

// ─── Events ───────────────────────────────────────────────────────────────────
resetBtn.addEventListener('click', () => {
  pasteInput.value = '';
  resultsDiv.innerHTML = '';
  errorBox.style.display = 'none';
  downloadBtn.style.display = 'none';
  lastDate = '';
});

calcBtn.addEventListener('click', () => {
  const raw = pasteInput.value.trim();
  if (!raw) { showError('Please paste your dispatch data first.'); return; }

  errorBox.style.display = 'none';
  resultsDiv.innerHTML   = '';
  downloadBtn.style.display = 'none';

  const trips = parseTrips(raw);
  if (!trips.length) {
    showError('Could not find any trip data. Make sure you copied the full table — each trip should have 13 lines.');
    return;
  }

  // Pull date from the first trip's tripDate field
  lastDate = trips[0].tripDate.match(/^\d{1,2}\/\d{1,2}\/\d{2,4}/)?.[0] || '';
  renderResults(trips, lastDate);
});

// ─── Helpers ──────────────────────────────────────────────────────────────────
function showError(msg) {
  errorBox.textContent   = msg;
  errorBox.style.display = 'block';
}

function fmt(n) { return '$' + Number(n).toFixed(2); }

// ─── Render ───────────────────────────────────────────────────────────────────
function renderResults(trips, date) {
  // Group by vehicle
  const groups = {};
  for (const t of trips) {
    if (!groups[t.vehicle]) groups[t.vehicle] = [];
    groups[t.vehicle].push(t);
  }

  const colors = ['#4fffb0', '#00c4ff', '#ffd166', '#ff6b6b', '#c77dff'];
  let html = '';
  let grandVP = 0, grand40 = 0, grandGrat = 0, grandTotal = 0;
  let ci = 0;

  // Date banner
  if (date) {
    html += `<div class="date-banner">
      <span class="date-icon">📅</span>
      <div>
        <div class="date-label">Report Date</div>
        <div class="date-value">${date}</div>
      </div>
    </div>`;
  }

  html += `<div class="section-label">Results by Vehicle</div>`;

  for (const [vehicle, vTrips] of Object.entries(groups)) {
    const color    = colors[ci++ % colors.length];
    const totalVP  = vTrips.reduce((s, t) => s + t.vPay, 0);
    const total40  = totalVP * 0.40;
    const totalGrat= vTrips.reduce((s, t) => s + t.gratuity, 0);
    const totalOut = total40 + totalGrat;

    grandVP    += totalVP;
    grand40    += total40;
    grandGrat  += totalGrat;
    grandTotal += totalOut;

    html += `
    <div class="vehicle-card" style="animation-delay:${(ci-1)*0.08}s">
      <div class="vehicle-header">
        <div class="vehicle-name" style="color:${color}">${vehicle}</div>
        <div class="vehicle-summary">
          <div class="summary-chip">
            <div class="label">Vehicle Pay</div>
            <div class="value">${fmt(totalVP)}</div>
          </div>
          <div class="summary-chip">
            <div class="label">40% Driver Pay</div>
            <div class="value" style="color:${color}">${fmt(total40)}</div>
          </div>
          <div class="summary-chip">
            <div class="label">Gratuity</div>
            <div class="value" style="color:var(--accent3)">${fmt(totalGrat)}</div>
          </div>
          <div class="summary-chip">
            <div class="label">Total Payout</div>
            <div class="value" style="color:${color};font-size:1.3rem">${fmt(totalOut)}</div>
          </div>
        </div>
      </div>
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Type</th>
            <th style="text-align:right">Vehicle Pay</th>
            <th style="text-align:right">40% Pay</th>
            <th style="text-align:right">Gratuity</th>
            <th style="text-align:right">Payout</th>
          </tr>
        </thead>
        <tbody>
          ${vTrips.map(t => {
            const pay40  = t.vPay * 0.4;
            const payout = pay40 + t.gratuity;
            return `<tr>
              <td class="name">${t.name}</td>
              <td>${t.svcType}</td>
              <td class="money">${fmt(t.vPay)}</td>
              <td class="money green">${fmt(pay40)}</td>
              <td class="money yellow">${fmt(t.gratuity)}</td>
              <td class="money" style="color:${color};font-weight:700">${fmt(payout)}</td>
            </tr>`;
          }).join('')}
        </tbody>
        <tfoot>
          <tr>
            <td colspan="2">Totals</td>
            <td>${fmt(totalVP)}</td>
            <td style="color:${color}">${fmt(total40)}</td>
            <td style="color:var(--accent3)">${fmt(totalGrat)}</td>
            <td style="color:${color}">${fmt(totalOut)}</td>
          </tr>
        </tfoot>
      </table>
    </div>`;
  }

  html += `
  <div class="section-label" style="margin-top:32px">Grand Totals — All Vehicles</div>
  <div class="global-totals">
    <div class="chip"><div class="label">Total Vehicle Pay</div><div class="val">${fmt(grandVP)}</div></div>
    <div class="chip"><div class="label">Total 40% Pay</div><div class="val">${fmt(grand40)}</div></div>
    <div class="chip"><div class="label">Total Gratuity</div><div class="val" style="color:var(--accent3)">${fmt(grandGrat)}</div></div>
    <div class="chip"><div class="label">Total Payout</div><div class="val" style="font-size:2.2rem">${fmt(grandTotal)}</div></div>
  </div>`;

  resultsDiv.innerHTML = html;
  downloadBtn.style.display = 'inline-flex';
}

// ─── Download ─────────────────────────────────────────────────────────────────
downloadBtn.addEventListener('click', () => {
  const content  = resultsDiv.innerHTML;
  if (!content) return;
  const dateSlug = lastDate ? lastDate.replace(/\//g, '-') : 'report';

  const html = `<!DOCTYPE html>
<html><head><meta charset="UTF-8"><title>Van Pay Report – ${lastDate}</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
body{background:#0d0f14;color:#e8eaf2;font-family:'Syne',sans-serif;padding:40px 20px;}
:root{--accent:#4fffb0;--accent3:#ffd166;--surface:#161a24;--card:#1e2433;--border:#2a3045;--muted:#6b7599;--radius:12px;}
.section-label{font-family:'DM Mono',monospace;font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:#6b7599;max-width:960px;margin:0 auto 16px;}
.date-banner{max-width:960px;margin:0 auto 28px;background:#161a24;border:1px solid #2a3045;border-left:4px solid #4fffb0;border-radius:12px;padding:14px 20px;display:flex;align-items:center;gap:12px;}
.date-banner .date-label{font-family:'DM Mono',monospace;font-size:0.7rem;text-transform:uppercase;color:#6b7599;}
.date-banner .date-value{font-size:1.1rem;font-weight:700;color:#4fffb0;}
.vehicle-card{background:#1e2433;border:1px solid #2a3045;border-radius:12px;margin-bottom:24px;overflow:hidden;max-width:960px;margin-left:auto;margin-right:auto;}
.vehicle-header{display:flex;align-items:center;justify-content:space-between;padding:18px 24px;background:#161a24;border-bottom:1px solid #2a3045;flex-wrap:wrap;gap:12px;}
.vehicle-name{font-size:1.4rem;font-weight:800;font-family:'DM Mono',monospace;}
.vehicle-summary{display:flex;gap:20px;flex-wrap:wrap;}
.summary-chip{text-align:right;}
.summary-chip .label{font-size:0.65rem;font-family:'DM Mono',monospace;color:#6b7599;text-transform:uppercase;}
.summary-chip .value{font-size:1.1rem;font-weight:700;}
table{width:100%;border-collapse:collapse;font-size:0.85rem;}
thead th{padding:10px 16px;text-align:left;font-family:'DM Mono',monospace;font-size:0.7rem;text-transform:uppercase;color:#6b7599;background:rgba(255,255,255,0.02);border-bottom:1px solid #2a3045;}
tbody tr{border-bottom:1px solid rgba(255,255,255,0.04);}
tbody td{padding:12px 16px;font-family:'DM Mono',monospace;color:#e8eaf2;}
td.money{text-align:right;}td.green{color:#4fffb0;font-weight:500;}td.yellow{color:#ffd166;font-weight:600;}
tfoot td{padding:12px 16px;font-family:'DM Mono',monospace;font-weight:600;background:rgba(79,255,176,0.05);border-top:1px solid #2a3045;text-align:right;}
tfoot td:first-child{text-align:left;color:#6b7599;text-transform:uppercase;font-size:0.7rem;font-weight:400;}
.global-totals{background:#161a24;border:1px solid rgba(79,255,176,0.2);border-radius:12px;padding:28px;margin-top:8px;display:flex;gap:32px;flex-wrap:wrap;justify-content:center;max-width:960px;margin-left:auto;margin-right:auto;}
.global-totals .chip{text-align:center;}
.global-totals .chip .label{font-family:'DM Mono',monospace;font-size:0.7rem;text-transform:uppercase;color:#6b7599;margin-bottom:6px;}
.global-totals .chip .val{font-size:1.9rem;font-weight:800;color:#4fffb0;}
h1{text-align:center;font-size:2rem;font-weight:800;background:linear-gradient(135deg,#4fffb0,#00c4ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:8px;}
.subtitle{text-align:center;color:#6b7599;font-family:'DM Mono',monospace;font-size:0.8rem;margin-bottom:40px;}
</style></head><body>
<h1>Van Pay Report</h1>
<p class="subtitle">Generated ${new Date().toLocaleString()}</p>
${content}
</body></html>`;

  const blob = new Blob([html], { type: 'text/html' });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href     = url;
  a.download = `van-pay-${dateSlug}.html`;
  a.click();
  URL.revokeObjectURL(url);
});
</script>
</body>
</html>
